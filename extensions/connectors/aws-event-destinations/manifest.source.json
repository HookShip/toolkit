{
  "manifestVersion": "1.0",
  "kind": "connector",
  "identity": {
    "id": "webhook-portal.connector.aws-event-destinations",
    "name": "AWS event destination configuration",
    "version": "0.1.0",
    "publisher": {
      "id": "webhook-portal.first-party-development",
      "name": "Webhook Portal first-party development assets",
      "url": "https://github.com/josedab/webhook-ideas"
    }
  },
  "compatibility": {
    "platform": "^0.1.0",
    "sdk": "^0.1.0",
    "dependencies": [],
    "conflicts": []
  },
  "capabilities": ["connector.configuration", "connector.templates"],
  "permissions": {},
  "resources": [
    {
      "path": "configuration.schema",
      "mediaType": "application/schema+json"
    },
    {
      "path": "destination-plan.template",
      "mediaType": "text/x-webhook-template"
    },
    {
      "path": "host-cloud-notes.md",
      "mediaType": "text/markdown"
    }
  ],
  "entry": {
    "type": "connector",
    "configurationSchema": "configuration.schema",
    "templates": ["destination-plan.template", "host-cloud-notes.md"]
  },
  "provenance": {
