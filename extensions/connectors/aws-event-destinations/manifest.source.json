    "build": {
      "builder": "webhook-portal-extension-seed-builder",
      "buildType": "data-only-source-pack",
      "timestamp": "2026-07-18T00:00:00.000Z",
      "reproducible": true
    },
    "sbom": {
      "format": "webhook-portal-sbom-v1",
      "dependencies": [
        {
          "name": "webhook-portal-extension-sdk",
          "version": "0.1.0",
          "relationship": "build",
          "direct": true,
          "license": "Apache-2.0",
          "purl": "pkg:npm/%40webhook-portal/extension-sdk@0.1.0"
        }
      ]
    }
  }
