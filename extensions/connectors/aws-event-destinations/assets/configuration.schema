{"$schema":"https://json-schema.org/draft/2020-12/schema","additionalProperties":false,"description":"Configuration for a host-managed AWS EventBridge or SQS event destination. This schema performs no provider call.","properties":{"accountId":{"description":"Twelve-digit AWS account identifier for host-side target validation.","maxLength":12,"minLength":12,"type":"string"},"destinationKind":{"description":"AWS destination family selected by the host.","enum":["eventbridge","sqs"],"type":"string"},"detailType":{"description":"EventBridge detail-type or equivalent SQS message attribute value.","maxLength":128,"minLength":1,"type":"string"},"hostMode":{"const":"host-managed-aws-api","default":"host-managed-aws-api","description":"Confirms that the host, not this extension, performs provider I/O.","type":"string"},"region":{"description":"AWS region used by the host-managed client.","maxLength":32,"minLength":1,"type":"string"},"roleReference":{"description":"Opaque reference to a host-managed role; never credential material.","maxLength":256,"minLength":1,"type":"string"},"source":{"description":"EventBridge source or equivalent SQS message attribute value.","maxLength":256,"minLength":1,"type":"string"},"target":{"description":"Exact event bus ARN/name or SQS queue ARN/URL validated by the host.","maxLength":2048,"minLength":1,"type":"string"}},"required":["accountId","destinationKind","detailType","hostMode","region","roleReference","source","target"],"title":"AWS event destination configuration","type":"object"}
