{"$schema":"https://json-schema.org/draft/2020-12/schema","additionalProperties":false,"description":"Illustrative metadata contract for asynchronous AI job notifications; not a service or outcome promise.","properties":{"eventId":{"description":"Unique callback event identifier.","maxLength":128,"minLength":1,"type":"string"},"eventType":{"description":"Illustrative callback event type.","enum":["ai.job.completed","ai.job.failed","ai.job.progress"],"type":"string"},"eventVersion":{"description":"Version of this illustrative callback contract.","maxLength":32,"minLength":1,"type":"string"},"job":{"additionalProperties":false,"description":"Job status metadata only; model inputs and outputs are not included.","properties":{"errorCode":{"description":"Stable producer-defined code when status is failed.","maxLength":128,"type":"string"},"id":{"description":"Producer job identifier.","maxLength":128,"minLength":1,"type":"string"},"progressPercent":{"description":"Optional informational progress value.","maximum":100,"minimum":0,"type":"number"},"resultReference":{"description":"Optional authorized location; consumers must authenticate separately.","format":"uri","type":"string"},"status":{"enum":["completed","failed","progress"],"type":"string"}},"required":["id","status"],"type":"object"},"occurredAt":{"description":"Producer-recorded event time.","format":"date-time","type":"string"}},"required":["eventId","eventType","eventVersion","job","occurredAt"],"title":"Illustrative AI asynchronous job callback","type":"object"}
