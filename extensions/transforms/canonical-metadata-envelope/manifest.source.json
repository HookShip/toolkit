{
  "manifestVersion": "1.0",
  "kind": "transform",
  "identity": {
    "id": "webhook-portal.transform.canonical-metadata-envelope",
    "name": "Canonical webhook metadata envelope",
    "version": "0.1.0",
    "publisher": {
      "id": "webhook-portal.first-party-development",
      "name": "Webhook Portal first-party development assets",
      "url": "https://github.com/josedab/webhook-ideas"
    }
  },
  "compatibility": {
    "platform": "^0.1.0",
    "sdk": "^0.1.0",
    "dependencies": [],
    "conflicts": []
  },
  "capabilities": ["transform.declarative"],
  "permissions": {
    "payloadRead": [
