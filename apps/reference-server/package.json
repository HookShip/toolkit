{
  "name": "@webhook-portal/reference-server",
  "version": "0.0.0",
  "private": true,
  "description": "Standalone open single-team webhook portal reference server.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "webhook-portal-reference-server": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "node dist/migrate.js",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:coverage": "node ../../scripts/test-coverage.mjs --project apps/reference-server",
    "pretypecheck": "pnpm --filter @webhook-portal/cli build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@webhook-portal/cli": "workspace:*"
  },
  "devDependencies": {
    "@webhook-portal/adapter-sdk": "workspace:*",
    "@webhook-portal/signing": "workspace:*",
    "fastify": "^5.10.0"
  }
}
