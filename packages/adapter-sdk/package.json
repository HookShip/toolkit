{
  "name": "@webhook-portal/adapter-sdk",
  "version": "0.1.0",
  "description": "Capability-driven webhook provider adapter SDK.",
  "keywords": [
    "webhook",
    "webhooks",
    "adapter",
    "sdk"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "node ../../scripts/test-coverage.mjs --project packages/adapter-sdk",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@webhook-portal/canonical-model": "workspace:*",
    "@webhook-portal/signing": "workspace:*"
  }
}
