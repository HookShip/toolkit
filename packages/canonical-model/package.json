{
  "name": "@webhook-portal/canonical-model",
  "version": "0.1.0",
  "description": "Canonical webhook contract model.",
  "keywords": [
    "webhook",
    "webhooks",
    "contract",
    "canonical-model"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:coverage": "node ../../scripts/test-coverage.mjs --project packages/canonical-model",
    "typecheck": "tsc -p tsconfig.test.json"
  }
}
