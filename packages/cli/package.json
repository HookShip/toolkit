{
  "name": "@webhook-portal/cli",
  "version": "0.1.0",
  "description": "Command-line tooling for local webhook contract workflows.",
  "keywords": [
    "webhook",
    "webhooks",
    "cli",
    "openapi",
    "asyncapi",
    "standard-webhooks"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "webhook-portal": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./reference-server": {
      "types": "./dist/reference-server/index.d.ts",
      "import": "./dist/reference-server/index.js"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:coverage": "node ../../scripts/test-coverage.mjs --project packages/cli",
    "test:integration": "vitest run test/reference-migrations.test.ts test/reference-repository.contract.test.ts test/reference-minio.integration.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@fastify/swagger": "^9.8.1",
    "@types/pg": "^8.20.0",
    "@webhook-portal/adapter-generic-http": "workspace:*",
    "@webhook-portal/adapter-sdk": "workspace:*",
    "@webhook-portal/canonical-model": "workspace:*",
    "@webhook-portal/contract-core": "workspace:*",
    "@webhook-portal/signing": "workspace:*",
    "fastify": "^5.10.0",
    "minio": "^8.0.7",
    "pg": "^8.22.0",
    "yaml": "^2.9.0"
  }
}
